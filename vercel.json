{
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-generate-subscription-cycles",
      "schedule": "0 2 * * *"
    },
    {
      "path": "/api/cron-check-missed-cycles",
      "schedule": "5 2 * * *"
    },
    {
      "path": "/api/cron-send-subscription-reminders",
      "schedule": "10 2 * * *"
    }
  ]
}
